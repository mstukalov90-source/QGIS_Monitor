              "schema": "lens",
              "geometry_column": "geometry"
            },
            {
              "table_name": "contours_wip",
              "display_name": "Контура в работе",
              "geometry_type": "polygon",
              "symbology": {
                "fill_color": "#FFFF00",
                "outline_color": "#FFFF00",
                "fill_opacity": 0.5,
                "outline_width": 1.0
              },
              "schema": "lens",
              "geometry_column": "geometry"
            },
            {
              "table_name": "contours_done",
              "display_name": "Контура выполненые",
              "geometry_type": "polygon",
              "symbology": {
                "fill_color": "#008000",
                "outline_color": "#008000",
                "fill_opacity": 0.5,
                "outline_width": 1.0
