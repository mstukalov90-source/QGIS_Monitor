          "geometry_type": "polygon",
          "schema": "odh_export",
          "geometry_column": "geom",
          "primary_key": "id",
          "sql_filter": "short_sobstv_rr IS NULL OR short_sobstv_rr NOT IN ('город Москва', 'Нет данных о правообладателе')",
          "symbology": {
            "fill_color": "#FFA500",
            "fill_opacity": 0.5,
            "outline_color": "#FFA500",
            "outline_width": 1.0,
            "hatch": {
              "enabled": true,
