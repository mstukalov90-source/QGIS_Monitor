          "geometry_type": "polygon",
          "schema": "odh_export",
          "geometry_column": "geom",
          "primary_key": "id",
          "sql_filter": "short_sobstv_rr = 'город Москва'",
          "symbology": {
            "fill_color": "#FF0000",
            "fill_opacity": 0.5,
            "outline_color": "#FF0000",
            "outline_width": 1.0,
            "hatch": {
              "enabled": true,
              "color": "#FFFFFF",
              "angle": 45,
              "spacing": 5
            }
