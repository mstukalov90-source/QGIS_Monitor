{
  "project": "QGIS Plugin Development",
  "task": "Database connection and layer visualization plugin",
  "version": "1.2.0",
  "description": "Plugin for connecting to PostgreSQL database and displaying spatial layers with predefined symbology",
  "database_connection": {
    "host": "77.222.63.161",
    "port": 5432,
    "database": "monitor",
    "username": "monitor",
    "password": "user_input_required",
    "connection_name": "Monitor DB Connection"
  },
  "layer_groups": [
    {
      "group_name": "Фото данные",
      "groups": [
        {
          "group_name": "Данные от ГенПлан",
          "layers": [
            {
              "table_name": "responses",
              "display_name": "Фотографии после обработки ИИ",
              "geometry_type": "point",
              "symbology": {
                "color": "#FF0000",
                "size": 4,
                "marker_type": "circle"
              },
              "schema": "genplan",
              "geometry_column": "photo_geom"
            },
            {
              "table_name": "responses",
              "display_name": "Полигоны заказов по фотографиям",
              "geometry_type": "polygon",
              "symbology": {
                "fill_color": "#800000",
                "outline_color": "#800000",
                "fill_opacity": 0.75,
                "outline_width": 1.0
              },
              "schema": "genplan",
              "geometry_column": "geom"
            }
          ]
        },
        {
          "group_name": "Данные Объектив",
          "layers": [
            {
              "table_name": "reports",
              "display_name": "Фото разрытий и строек",
              "geometry_type": "point",
              "symbology": {
                "complex_marker": true,
                "center_color": "#000000",
                "outer_color": "#FF0000",
                "outer_width": 2,
                "size": 6,
                "marker_type": "circle_with_border"
              },
              "schema": "lens",
              "geometry_column": "geom"
            },
            {
              "table_name": "contours",
