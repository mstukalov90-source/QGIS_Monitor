{
  "project": "QGIS Plugin Development",
  "task": "Database connection and layer visualization plugin",
  "version": "1.15.0",
  "description": "Plugin for connecting to PostgreSQL database and displaying spatial layers with predefined symbology",
  "database_connection": {
    "host": "77.222.63.161",
    "port": 5432,
    "database": "monitor",
