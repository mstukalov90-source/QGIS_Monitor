        {
          "group_name": "Данные от ГенПлан",
          "layers": [
            {
              "table_name": "photo_meta",
              "display_name": "Фотографии после обработки ИИ",
              "geometry_type": "point",
              "symbology": {
                "color": "#FF0000",
                "size": 4,
                "marker_type": "circle"
              },
              "schema": "genplan",
              "geometry_column": "geom",
              "sql_filter": "disruption = true"
